# ═══════════════════════════════════════════════════════════
#  AI English Learning — single .env for the whole project
#  cp .env.example .env  then fill in the values below
# ═══════════════════════════════════════════════════════════

# ── Ports ─────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
REDIS_PORT=6379

# ── PostgreSQL (your existing server DB) ──────────────────
DATABASE_URL=postgresql+psycopg2://postgres:yourpassword@localhost:5432/ai_english_learning

# ── App ───────────────────────────────────────────────────
APP_NAME=AI English Learning API
APP_ENV=production

# ── Security (CHANGE THIS before deploying) ──────────────
JWT_SECRET_KEY=change-me-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Admin ─────────────────────────────────────────────────
ADMIN_EMAILS=admin@xyz.com

# ── OpenAI (required for AI chat, voice, and TTS) ────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=mp3

# ── Grammar checker ───────────────────────────────────────
LANGUAGETOOL_API_URL=https://api.languagetool.org/v2/check
LANGUAGETOOL_LANGUAGE=en-US

# ── AI behaviour ──────────────────────────────────────────
AI_CONVERSATION_MEMORY_LIMIT=10
REDIS_SESSION_TTL_SECONDS=3600
REDIS_AI_CACHE_TTL_SECONDS=1800
