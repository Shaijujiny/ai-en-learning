DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_interview_platform
APP_NAME=AI Interview Platform API
APP_ENV=development
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
ADMIN_EMAILS=
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=mp3
LANGUAGETOOL_API_URL=https://api.languagetool.org/v2/check
LANGUAGETOOL_LANGUAGE=en-US
REDIS_URL=
REDIS_SESSION_TTL_SECONDS=3600
REDIS_AI_CACHE_TTL_SECONDS=1800
AI_CONVERSATION_MEMORY_LIMIT=10
